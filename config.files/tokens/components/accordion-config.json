    "figmaPage": "🟠 - Components",
    "figmaFile": "m2iOWX3I9aDI5kgyw4wCo0",
    "description": "General-purpose collapsible content section with a clickable header and expandable body area. Supports Default and Bordered styles, three interaction states, and an optional chevron icon.",
    "variantAxes": ["State", "Style"],
    "booleanProperties": ["ShowIcon"]
  },

  "variants": {
    "stateValues": ["Collapsed", "Expanded", "Disabled"],
    "styleValues": ["Default", "Bordered"]
  },

  "booleanProperties": {
    "ShowIcon": {
      "type": "BOOLEAN",
      "default": true,
      "controls": "ChevronIcon visibility inside AccordionHeader"
    }
  },

  "variantMatrix": [
    { "State": "Collapsed", "Style": "Default",  "height": 48,   "width": 480, "contentVisible": false },
    { "State": "Expanded",  "Style": "Default",  "height": "AUTO","width": 480, "contentVisible": true  },
    { "State": "Disabled",  "Style": "Default",  "height": 48,   "width": 480, "contentVisible": false },
    { "State": "Collapsed", "Style": "Bordered", "height": 48,   "width": 480, "contentVisible": false },
    { "State": "Expanded",  "Style": "Bordered", "height": "AUTO","width": 480, "contentVisible": true  },
    { "State": "Disabled",  "Style": "Bordered", "height": 48,   "width": 480, "contentVisible": false }
