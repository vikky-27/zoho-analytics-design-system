  "instantiationPattern": {
    "description": "Search the library first. If found, use importComponentByKeyAsync with a variant key. If not found in library, scan local pages by COMPONENT_SET name 'Accordion'. Fall back to custom build only if both searches return nothing.",
    "searchAliases": ["Accordion", "Collapsible", "Expandable", "Expandable Section", "Collapse Panel"],
    "localPageScan": {
      "pageName": "🟠 - Components",
      "searchName": "Accordion"
    },
    "setPropertiesExample": {
      "code": "instance.setProperties({ 'State': 'Expanded', 'Style': 'Default', 'ShowIcon': true });"
    },
    "sizingAfterAppend": "instance.layoutSizingHorizontal = 'FILL';"
  },

  "hardRules": [
    "Never hardcode hex values — use setBoundVariableForPaint() with the variableId from this file.",
    "Never resize height — set primaryAxisSizingMode = 'HUG' and let content drive height.",
    "Set layoutSizingHorizontal = 'FILL' only AFTER appending to a parent auto-layout frame.",
    "AccordionContent visibility is driven by the State variant — never force-show it on a Collapsed variant.",
    "ShowIcon is a BOOLEAN component property — toggle via setProperties(), never via layer.visible directly.",
    "Run token-audit.js before marking the component done when building from scratch."
  ]
