{
  "_meta": {
    "version": "1.0.0",
    "updatedAt": "2026-04-17",
    "figmaFileKey": "m2iOWX3I9aDI5kgyw4wCo0",
    "purpose": "Master Figma library variable binding map. Use this file for ALL component creation — both new and existing. Every color must be bound via figma.variables.setBoundVariableForPaint(), never hardcoded.",
    "_collections": {
      "tokens":     "VariableCollectionId:575:225",
      "primitives": "VariableCollectionId:5:2156"
    }
  },

  "_hardRule": "NEVER use raw hex values, {r,g,b} objects, or hexToRgb() helpers when applying fills or strokes in Figma plugin scripts. ALWAYS look up the variable ID from this file and call figma.variables.setBoundVariableForPaint().",

  "_codePattern": [
    "// 1. Load the variable by ID",
    "const v = await figma.variables.getVariableByIdAsync(BINDINGS.<role>.variableId);",
    "",
    "// 2. Create a bound paint (variable overrides the base color at runtime)",
    "const paint = figma.variables.setBoundVariableForPaint(",
    "  { type: 'SOLID', color: { r: 0, g: 0, b: 0 } },",
    "  'color',",
    "  v",
    ");",
    "",
    "// 3. Assign",
    "node.fills  = [paint];   // for fills",
    "node.strokes = [paint];  // for strokes"
  ],

